# =================================================
# ECS Backend Environment Variables
# Copy this to .env and fill in your values
# =================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# --- DashScope (Alibaba Model Studio) ---
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- CORS ---
ALLOWED_ORIGIN=https://your-app.vercel.app

# --- Alibaba Cloud OSS (Singapore) ---
OSS_BUCKET=ai-film-studio-media
OSS_REGION=oss-ap-southeast-1
OSS_INTERNAL=true
# Option 1: ECS RAM Role (recommended for production)
ECS_RAM_ROLE=your-ecs-ram-role-name
# Option 2: Explicit keys (development only)
# ALIBABA_ACCESS_KEY_ID=your-key
# ALIBABA_ACCESS_KEY_SECRET=your-secret

# --- Encryption ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY_V1=your-64-hex-char-key-here
ENCRYPTION_KEY_VERSION=1
HMAC_SECRET=your-hmac-secret

# --- Kill Switch ---
KILL_SWITCH=0

# --- Budget ---
DAILY_CREDIT_LIMIT_USD=5.00

# --- API Domain ---
API_DOMAIN=api.yourdomain.com

# --- Telegram Proxy (Bypass Firewall) ---
TELEGRAM_API_URL=https://your-app.vercel.app/api/telegram-proxy
TELEGRAM_RELAY_SECRET=your-relay-secret-here

# --- Limits ---
MAX_NODE_EXECUTIONS_PER_PIPELINE=30
MAX_MEDIA_CALLS_PER_PIPELINE=5

# --- Outbox ---
OUTBOX_POLL_INTERVAL_MS=1000

# --- Mock Mode (development) ---
USE_MOCK_MEDIA=false
